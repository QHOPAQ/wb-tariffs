{
  "name": "wb-tariffs-sync-service",
  "version": "1.0.0",
  "description": "Wildberries tariffs background sync service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node -r ts-node/register ./node_modules/knex/bin/cli.js --knexfile src/db/knexfile.ts migrate:latest"
  },
  "dependencies": {
    "@googleapis/sheets": "^9.0.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "googleapis": "^171.4.0",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
