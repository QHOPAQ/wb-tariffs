# Основные настройки приложения
PORT=3000
NODE_ENV=development

# Подключение к PostgreSQL (обычно локально или в docker-compose)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Wildberries API - вставь свой токен, без него ничего не будет работать
WB_API_TOKEN=PASTE_YOUR_WB_TOKEN_HERE

# Google Sheets - куда выгружать данные
# Можно несколько ID через запятую без пробелов
GOOGLE_SPREADSHEET_IDS=1abcDEF123...,2xyz789...
GOOGLE_SHEET_NAME=stocks_coefs   # имя листа внутри каждой таблицы

# Google Service Account credentials - нужно ОДНО из двух:

# Вариант 1: base64-строка (удобно в docker, kubernetes secrets)
# GOOGLE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6InlvdXItcHJvamVjdCIsInByaXZhdGVfa2V5X2lkIjoi... (очень длинная строка)

# Вариант 2: путь к файлу json (удобно при локальной разработке)
GOOGLE_SERVICE_ACCOUNT_FILE=./google-credentials.json

# Если оба варианта пустые - синхронизация в Google Sheets отключится автоматически